{
    "name": "orzubek-rakhimov/laravel-sdui",
    "description": "Server-Driven UI framework for Laravel - Build dynamic, native-like mobile and web interfaces declaratively in PHP",
    "version": "1.0.0",
    "type": "library",
    "autoload": {
        "psr-4": {
            "SDUI\\": "src/"
        },
        "classmap": [
            "src/Components/Components.php"
        ]
    },
    "authors": [
        {
            "name": "Rahimov Orzubek",
            "email": "145760665+Orzubek-Rakhimov@users.noreply.github.com"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "SDUI\\SDUIServiceProvider"
            ],
            "aliases": {
                "SDUI": "SDUI\\Facades\\SDUI"
            }
    }
  },
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html coverage --coverage-text",
        "test:watch": "phpunit --watch"
    }
}
